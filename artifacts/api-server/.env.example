# Copy this file to `.env` in the same directory and fill in real values.
# This file is loaded automatically by `node --env-file-if-exists=.env` when the
# api-server starts.

# ── DataSling Bulk SMS ────────────────────────────────────────────────────────
DATASLING_SMS_USERNAME=trustbank
DATASLING_SMS_PASSWORD=your-api-password-here
DATASLING_SMS_BEARER_TOKEN=your-bearer-token-here
DATASLING_SMS_SENDER=TrustBank
# Optional override (defaults to https://sms-api.datasling.gm/bulksms)
# DATASLING_SMS_BASE_URL=https://sms-api.datasling.gm/bulksms

# ── Outlook / Microsoft 365 SMTP (filled in once we agree on the approach) ───
# OUTLOOK_SMTP_HOST=smtp.office365.com
# OUTLOOK_SMTP_PORT=587
# OUTLOOK_SMTP_USER=notifications@trustbank.gm
# OUTLOOK_SMTP_PASSWORD=
# OUTLOOK_FROM_NAME=Trust Bank
